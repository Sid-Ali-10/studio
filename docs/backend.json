
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's public profile within the GetMeDZ marketplace, storing display information, ratings, deal history, and wallet balance.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the UserProfile entity."
        },
        "username": {
          "type": "string",
          "description": "The public username displayed for the user."
        },
        "email": {
          "type": "string",
          "description": "The email address associated with the user's account.",
          "format": "email"
        },
        "averageRating": {
          "type": "number",
          "description": "The average star rating received by the user."
        },
        "successfulDealsCount": {
          "type": "number",
          "description": "The total number of successful transactions completed."
        },
        "walletBalance": {
          "type": "number",
          "description": "The current amount of money in the user's virtual wallet in DA."
        },
        "isVerified": {
          "type": "boolean",
          "description": "Indicates if the user's account has been verified."
        },
        "isAdmin": {
          "type": "boolean",
          "description": "Indicates if the user has administrative privileges."
        },
        "isBanned": {
          "type": "boolean",
          "description": "Indicates if the user's account has been suspended for violations."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "username",
        "email",
        "walletBalance",
        "createdAt",
        "updatedAt"
      ]
    },
    "Revenue": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Revenue",
      "type": "object",
      "description": "Global log for subscription sales revenue.",
      "properties": {
        "id": { "type": "string" },
        "amount": { "type": "number" },
        "buyerId": { "type": "string" },
        "buyerName": { "type": "string" },
        "packageName": { "type": "string" },
        "creditsGiven": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["amount", "buyerId", "packageName", "createdAt"]
    },
    "Report": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Report",
      "type": "object",
      "description": "Represents a user report regarding another user or a specific conversation.",
      "properties": {
        "id": { "type": "string" },
        "reporterId": { "type": "string" },
        "targetUserId": { "type": "string" },
        "conversationId": { "type": "string" },
        "type": { "type": "string", "enum": ["scam", "harassment", "fraud", "other"] },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "reviewed", "ignored", "resolved"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "reporterId", "type", "reason", "status", "createdAt"]
    },
    "Transaction": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Transaction",
      "type": "object",
      "description": "Records a financial movement within a user's wallet.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["recharge", "payment", "payout", "commission"] },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "amount", "type", "createdAt"]
    },
    "Listing": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Listing",
      "type": "object",
      "description": "Represents either a traveler's offer of luggage space or a buyer's request.",
      "properties": {
        "id": { "type": "string" },
        "listerId": { "type": "string" },
        "type": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "originCity": { "type": "string" },
        "destinationCity": { "type": "string" },
        "arrivalDate": { "type": "string", "format": "date" },
        "availableLuggageWeightKg": { "type": "number" },
        "productName": { "type": "string" },
        "maxPriceAmount": { "type": "number" },
        "currency": { "type": "string" },
        "productUrl": { "type": "string", "format": "uri" },
        "listingImageUrl": { "type": "string", "format": "uri" }
      },
      "required": ["id", "listerId", "type", "title", "description", "status", "createdAt", "updatedAt"]
    },
    "Conversation": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Conversation",
      "type": "object",
      "description": "Represents a private chat room.",
      "properties": {
        "id": { "type": "string" },
        "participantIds": { "type": "array", "items": { "type": "string" } },
        "listingId": { "type": "string" },
        "lastMessageText": { "type": "string" },
        "lastMessageTimestamp": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "agreedPrice": { "type": "number" },
        "offeredPrice": { "type": "number" },
        "offerSenderId": { "type": "string" }
      },
      "required": ["id", "participantIds", "listingId", "createdAt", "updatedAt"]
    },
    "Message": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Message",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "conversationId": { "type": "string" },
        "senderId": { "type": "string" },
        "messageText": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "timestamp": { "type": "string", "format": "date-time" },
        "isRead": { "type": "boolean" }
      },
      "required": ["id", "conversationId", "senderId", "timestamp"]
    },
    "Rating": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Rating",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "listingId": { "type": "string" },
        "raterId": { "type": "string" },
        "ratedUserId": { "type": "string" },
        "stars": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "listingId", "raterId", "ratedUserId", "stars", "createdAt"]
    },
    "PlatformConfig": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PlatformConfig",
      "type": "object",
      "properties": {
        "defaultCommission": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/userProfiles/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "Stores individual user profiles."
        }
      },
      {
        "path": "/revenue/{revenueId}",
        "definition": {
          "entityName": "Revenue",
          "schema": { "$ref": "#/backend/entities/Revenue" },
          "description": "Global revenue tracking collection."
        }
      },
      {
        "path": "/reports/{reportId}",
        "definition": {
          "entityName": "Report",
          "schema": { "$ref": "#/backend/entities/Report" },
          "description": "User complaints."
        }
      },
      {
        "path": "/settings/config",
        "definition": {
          "entityName": "PlatformConfig",
          "schema": { "$ref": "#/backend/entities/PlatformConfig" },
          "description": "Global settings."
        }
      },
      {
        "path": "/userProfiles/{userId}/transactions/{transactionId}",
        "definition": {
          "entityName": "Transaction",
          "schema": { "$ref": "#/backend/entities/Transaction" },
          "description": "User specific logs."
        }
      },
      {
        "path": "/listings/{listingId}",
        "definition": {
          "entityName": "Listing",
          "schema": { "$ref": "#/backend/entities/Listing" },
          "description": "Marketplace listings."
        }
      },
      {
        "path": "/conversations/{conversationId}",
        "definition": {
          "entityName": "Conversation",
          "schema": { "$ref": "#/backend/entities/Conversation" },
          "description": "Chat metadata."
        }
      },
      {
        "path": "/conversations/{conversationId}/messages/{messageId}",
        "definition": {
          "entityName": "Message",
          "schema": { "$ref": "#/backend/entities/Message" },
          "description": "Messages."
        }
      },
      {
        "path": "/ratings/{ratingId}",
        "definition": {
          "entityName": "Rating",
          "schema": { "$ref": "#/backend/entities/Rating" },
          "description": "User ratings."
        }
      },
      {
        "path": "/userProfiles/{userId}/favorites/{favoriteId}",
        "definition": {
          "entityName": "Favorite",
          "schema": { "$ref": "#/backend/entities/Favorite" },
          "description": "Favorites."
        }
      },
      {
        "path": "/subscriptionPackages/{packageId}",
        "definition": {
          "entityName": "SubscriptionPackage",
          "schema": { "type": "object" },
          "description": "Managed by admin."
        }
      }
    ]
  }
}

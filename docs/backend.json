
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's public profile within the GetMeDZ marketplace, storing display information, ratings, deal history, and wallet balance.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the UserProfile entity."
        },
        "username": {
          "type": "string",
          "description": "The public username displayed for the user."
        },
        "email": {
          "type": "string",
          "description": "The email address associated with the user's account.",
          "format": "email"
        },
        "averageRating": {
          "type": "number",
          "description": "The average star rating received by the user."
        },
        "successfulDealsCount": {
          "type": "number",
          "description": "The total number of successful transactions completed."
        },
        "walletBalance": {
          "type": "number",
          "description": "The current amount of money in the user's virtual wallet in DA."
        },
        "isVerified": {
          "type": "boolean",
          "description": "Indicates if the user's account has been verified."
        },
        "isAdmin": {
          "type": "boolean",
          "description": "Indicates if the user has administrative privileges."
        },
        "isBanned": {
          "type": "boolean",
          "description": "Indicates if the user's account has been suspended for violations."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "username",
        "email",
        "walletBalance",
        "createdAt",
        "updatedAt"
      ]
    },
    "Report": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Report",
      "type": "object",
      "description": "Represents a user report regarding another user or a specific conversation.",
      "properties": {
        "id": {
          "type": "string"
        },
        "reporterId": {
          "type": "string"
        },
        "targetUserId": {
          "type": "string"
        },
        "conversationId": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": ["scam", "harassment", "fraud", "other"]
        },
        "reason": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "reviewed", "ignored", "resolved"]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["id", "reporterId", "type", "reason", "status", "createdAt"]
    },
    "Transaction": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Transaction",
      "type": "object",
      "description": "Records a financial movement within a user's wallet (recharge or payment).",
      "properties": {
        "id": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "amount": {
          "type": "number",
          "description": "The amount of the transaction. Positive for recharge, negative for payment."
        },
        "type": {
          "type": "string",
          "enum": ["recharge", "payment", "payout", "commission"]
        },
        "description": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["id", "userId", "amount", "type", "createdAt"]
    },
    "Listing": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Listing",
      "type": "object",
      "description": "Represents either a traveler's offer of luggage space or a buyer's request for a product from abroad.",
      "properties": {
        "id": {
          "type": "string"
        },
        "listerId": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "originCity": {
          "type": "string"
        },
        "destinationCity": {
          "type": "string"
        },
        "arrivalDate": {
          "type": "string",
          "format": "date"
        },
        "availableLuggageWeightKg": {
          "type": "number"
        },
        "productName": {
          "type": "string"
        },
        "maxPriceAmount": {
          "type": "number"
        },
        "currency": {
          "type": "string"
        },
        "productUrl": {
          "type": "string",
          "format": "uri"
        },
        "listingImageUrl": {
          "type": "string",
          "format": "uri"
        }
      },
      "required": [
        "id",
        "listerId",
        "type",
        "title",
        "description",
        "status",
        "createdAt",
        "updatedAt"
      ]
    },
    "Conversation": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Conversation",
      "type": "object",
      "description": "Represents a private chat room between two users related to a specific listing.",
      "properties": {
        "id": {
          "type": "string"
        },
        "participantIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "listingId": {
          "type": "string"
        },
        "lastMessageText": {
          "type": "string"
        },
        "lastMessageTimestamp": {
          "type": "string",
          "format": "date-time"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "agreedPrice": {
          "type": "number"
        },
        "offeredPrice": {
          "type": "number"
        },
        "offerSenderId": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "participantIds",
        "listingId",
        "createdAt",
        "updatedAt"
      ]
    },
    "Message": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Message",
      "type": "object",
      "description": "Represents an individual message sent within a conversation.",
      "properties": {
        "id": {
          "type": "string"
        },
        "conversationId": {
          "type": "string"
        },
        "senderId": {
          "type": "string"
        },
        "messageText": {
          "type": "string"
        },
        "imageUrl": {
          "type": "string",
          "format": "uri"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "isRead": {
          "type": "boolean"
        }
      },
      "required": [
        "id",
        "conversationId",
        "senderId",
        "timestamp"
      ]
    },
    "Rating": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Rating",
      "type": "object",
      "description": "Represents a star rating given by one user to another user's listing.",
      "properties": {
        "id": {
          "type": "string"
        },
        "listingId": {
          "type": "string"
        },
        "raterId": {
          "type": "string"
        },
        "ratedUserId": {
          "type": "string"
        },
        "stars": {
          "type": "number"
        },
        "comment": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "listingId",
        "raterId",
        "ratedUserId",
        "stars",
        "createdAt"
      ]
    },
    "PlatformConfig": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PlatformConfig",
      "type": "object",
      "description": "Global settings for the GetMeDZ platform.",
      "properties": {
        "defaultCommission": {
          "type": "number",
          "description": "The default commission amount in DA deducted from travelers."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/userProfiles/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          },
          "description": "Stores individual user profiles.",
          "params": [
            {
              "name": "userId",
              "description": "The unique ID of the user."
            }
          ]
        }
      },
      {
        "path": "/reports/{reportId}",
        "definition": {
          "entityName": "Report",
          "schema": {
            "$ref": "#/backend/entities/Report"
          },
          "description": "Stores user complaints and fraud reports.",
          "params": [
            {
              "name": "reportId",
              "description": "The unique ID of the report."
            }
          ]
        }
      },
      {
        "path": "/settings/config",
        "definition": {
          "entityName": "PlatformConfig",
          "schema": {
            "$ref": "#/backend/entities/PlatformConfig"
          },
          "description": "Global platform settings."
        }
      },
      {
        "path": "/userProfiles/{userId}/transactions/{transactionId}",
        "definition": {
          "entityName": "Transaction",
          "schema": {
            "$ref": "#/backend/entities/Transaction"
          },
          "description": "Records of financial transactions for a specific user.",
          "params": [
            {
              "name": "userId",
              "description": "The unique ID of the user."
            },
            {
              "name": "transactionId",
              "description": "The unique ID of the transaction."
            }
          ]
        }
      },
      {
        "path": "/listings/{listingId}",
        "definition": {
          "entityName": "Listing",
          "schema": {
            "$ref": "#/backend/entities/Listing"
          },
          "description": "Stores all marketplace listings.",
          "params": [
            {
              "name": "listingId",
              "description": "The unique ID of the listing."
            }
          ]
        }
      },
      {
        "path": "/conversations/{conversationId}",
        "definition": {
          "entityName": "Conversation",
          "schema": {
            "$ref": "#/backend/entities/Conversation"
          },
          "description": "Stores metadata for private chat conversations.",
          "params": [
            {
              "name": "conversationId",
              "description": "The unique ID of the conversation."
            }
          ]
        }
      },
      {
        "path": "/conversations/{conversationId}/messages/{messageId}",
        "definition": {
          "entityName": "Message",
          "schema": {
            "$ref": "#/backend/entities/Message"
          },
          "description": "Stores individual messages within a conversation.",
          "params": [
            {
              "name": "conversationId",
              "description": "The unique ID of the parent conversation."
            },
            {
              "name": "messageId",
              "description": "The unique ID of the message."
            }
          ]
        }
      },
      {
        "path": "/ratings/{ratingId}",
        "definition": {
          "entityName": "Rating",
          "schema": {
            "$ref": "#/backend/entities/Rating"
          },
          "description": "Stores user ratings.",
          "params": [
            {
              "name": "ratingId",
              "description": "The unique ID of the rating."
            }
          ]
        }
      },
      {
        "path": "/userProfiles/{userId}/favorites/{favoriteId}",
        "definition": {
          "entityName": "Favorite",
          "schema": {
            "$ref": "#/backend/entities/Favorite"
          },
          "description": "Stores a user's favorited listings.",
          "params": [
            {
              "name": "userId",
              "description": "The unique ID of the user."
            },
            {
              "name": "favoriteId",
              "description": "The unique ID of the favorite entry."
            }
          ]
        }
      }
    ]
  }
}


rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(ownerId) {
      return resource != null && isOwner(ownerId);
    }

    function isParticipant(participantIds) {
      return isSignedIn() && participantIds != null && (request.auth.uid in participantIds);
    }

    function isAdmin() {
      // Check if the user document has the isAdmin flag set
      // Use exists() check to prevent rule failure if doc doesn't exist
      return isSignedIn() && 
             exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.isAdmin == true;
    }

    // --- Collection Rules ---

    match /userProfiles/{userId} {
      allow get: if true;
      allow list: if isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      // Allow users to update their own profile (stats and balance)
      // and allow them to update 'isAdmin' if they are already an admin
      // Special allowance: if a user is setting their OWN isAdmin to true, we allow it for development flow
      allow update: if isExistingOwner(userId) || isAdmin() || (isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isAdmin', 'updatedAt']));
      allow delete: if isExistingOwner(userId) || isAdmin();

      match /favorites/{favoriteId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) || isAdmin();
        allow delete: if isExistingOwner(userId) || isAdmin();
      }

      match /transactions/{transactionId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId);
        allow update: if isAdmin();
        allow delete: if isAdmin();
      }
    }

    match /listings/{listingId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.listerId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.listerId) || isAdmin();
      allow delete: if isExistingOwner(resource.data.listerId) || isAdmin();
    }

    match /conversations/{conversationId} {
      // Global list only for admins
      allow list: if isAdmin();
      
      // Individual get and filtered list (if implemented) for participants
      allow get: if isParticipant(resource.data.participantIds) || isAdmin();
      
      allow create: if isSignedIn() && isParticipant(request.resource.data.participantIds);
      allow update: if isParticipant(resource.data.participantIds) || isAdmin();
      allow delete: if isParticipant(resource.data.participantIds) || isAdmin();

      match /messages/{messageId} {
        // Messages are usually fetched within a conversation context
        allow get, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isAdmin();
      }
    }

    match /ratings/{ratingId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.raterId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.raterId) || isAdmin();
      allow delete: if isExistingOwner(resource.data.raterId) || isAdmin();
    }
  }
}
